# A2A Multi-Agent System Environment Configuration
# Copy this file to '.env' and fill in your actual API keys

# Required: OpenAI API key for AI-powered code generation and review
# Get your key from: https://platform.openai.com/account/api-keys
OPENAI_API_KEY=sk-your-openai-api-key-here

# Required: Traceloop API key for trace dashboard visualization
# Get your key from: https://app.traceloop.com/settings/api-keys
TRACELOOP_API_KEY=tl_your-traceloop-api-key-here

# Optional: Custom Traceloop endpoint (defaults to api.traceloop.com)
TRACELOOP_BASE_URL=https://api.traceloop.com

# Optional: Environment identifier (development/staging/production)
ENVIRONMENT=development

# Optional: Enable debug logging (true/false)
DEBUG=false